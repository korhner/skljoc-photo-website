---
import BaseLayout from '@components/layout/BaseLayout.astro';
import Button from '@components/ui/Button.astro';

const galleryImages = [
  { src: '/images/optimized/family/407A3510.webp', alt: 'Porodična fotografija - park' },
  { src: '/images/optimized/family/407A0016.webp', alt: 'Porodična fotografija - portreti' },
  { src: '/images/optimized/family/407A9941.webp', alt: 'Porodična fotografija - priroda' },
  { src: '/images/optimized/family/407A0163_3.webp', alt: 'Porodična fotografija - zagrljaj' },
  { src: '/images/optimized/family/407A3732-2.webp', alt: 'Porodična fotografija - šetnja' },
  { src: '/images/optimized/family/407A9954.webp', alt: 'Porodična fotografija - ljubav' },
];

const faqs = [
  {
    question: 'Gde se može organizovati porodično fotografisanje?',
    answer: 'Fotografišemo na lokaciji po vašem izboru — parkovi, ulice Beograda, vaš dom ili studio. Rado ću predložiti lokacije koje najbolje odgovaraju vašoj viziji.'
  },
  {
    question: 'Šta treba da obučemo za fotografisanje?',
    answer: 'Preporučujem udobnu odeću u neutralnim tonovima, bez velikih logotipova. Usklađeni (ne identični) outfiti daju najlepši efekat. Rado ću pomoći sa savetima!'
  },
  {
    question: 'Da li fotografišete i manje grupe, npr. samo mamu i dete?',
    answer: 'Naravno! Fotografisanje je prilagođeno vama — bilo da ste par, roditelj sa detetom, cela porodica ili više generacija zajedno.'
  },
  {
    question: 'Šta ako deca ne sarađuju tokom fotografisanja?',
    answer: 'To je sasvim normalno i očekivano! Imam puno strpljenja i iskustva sa decom. Najbolje fotografije nastaju upravo u spontanim trenucima, bez forsiranja.'
  }
];
---

<BaseLayout
  title="Porodično fotografisanje u Beogradu"
  description="Profesionalno porodično fotografisanje u Beogradu. Prirodni i autentični porodični portreti na lokaciji po vašem izboru. Paketi već od 60€."
  keywords="porodični fotograf Beograd, porodično fotografisanje, porodični portreti, fotograf za porodicu Beograd, family photo session Belgrade"
  ogImage="https://www.draganakorhner.photography/images/optimized/family/407A3510.webp"
>
  <!-- Hero Section -->
  <section class="relative min-h-[60vh] flex items-center mt-16">
    <div class="absolute inset-0">
      <img
        src="/images/optimized/family/407A3510.webp"
        alt="Porodično fotografisanje"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/60 to-black/20"></div>
    </div>
    <div class="container relative z-10">
      <div class="max-w-2xl text-white">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading mb-6">
          Porodična fotografisanja
        </h1>
        <p class="text-lg md:text-xl mb-8 text-white/90">
          Bilo da želite piknik u prirodi, šetnju kroz grad ili nežne trenutke kod kuće — fotografisanje će biti prilagođeno vama i vašoj priči.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href="/contact">Zakažite termin</Button>
          <Button href="#paketi" variant="outline" class="!border-white !text-white hover:!bg-white hover:!text-text-dark">Pogledajte pakete</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- O usluzi -->
  <section class="py-20">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-heading mb-6">
            Vaša porodica, vaša <span class="highlight">priča</span>
          </h2>
          <p class="text-text-light mb-4">
            Svaka porodica ima svoju jedinstvenu energiju, svoj ritam i svoje male rituale.
            Moj pristup je da vas upoznam, da se opustite pred objektivom i da zajedno
            stvorimo fotografije koje zaista liče na vas.
          </p>
          <p class="text-text-light mb-4">
            Kombinujem postavljene portrete sa spontanim momentima — zagrljaji, pogledi,
            smeh koji ne možete da kontrolišete. Upravo ti trenuci čine vaše fotografije posebnim.
          </p>
          <p class="text-text-light">
            Fotografišem na otvorenom, u parkovima, na ulicama Beograda, ali i u vašem domu —
            tamo gde se osećate najopuštenije.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <img
            src="/images/optimized/family/407A0189_2.webp"
            alt="Porodični portret"
            class="rounded-lg shadow-lg w-full h-auto"
          />
          <img
            src="/images/optimized/family/407A9982.webp"
            alt="Porodica u prirodi"
            class="rounded-lg shadow-lg w-full h-auto mt-8"
          />
          <img
            src="/images/optimized/family/407A0193_1.webp"
            alt="Mama i dete"
            class="rounded-lg shadow-lg w-full h-auto"
          />
          <img
            src="/images/optimized/family/407A1845.webp"
            alt="Porodična ljubav"
            class="rounded-lg shadow-lg w-full h-auto mt-8"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Kako izgleda proces -->
  <section class="py-20 bg-primary/10">
    <div class="container">
      <h2 class="text-3xl md:text-4xl font-heading text-center mb-12">
        Kako <span class="highlight">izgleda</span> proces?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-secondary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-secondary text-2xl font-heading">1</span>
          </div>
          <h3 class="font-heading text-lg mb-2">Dogovor</h3>
          <p class="text-text-light text-sm">Razgovaramo o vašim željama, biramo lokaciju i datum.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-secondary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-secondary text-2xl font-heading">2</span>
          </div>
          <h3 class="font-heading text-lg mb-2">Fotografisanje</h3>
          <p class="text-text-light text-sm">Opušteno fotografisanje u prijatnoj atmosferi, bez žurbe.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-secondary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-secondary text-2xl font-heading">3</span>
          </div>
          <h3 class="font-heading text-lg mb-2">Obrada</h3>
          <p class="text-text-light text-sm">Pažljivo biram i profesionalno obrađujem svaku fotografiju.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-secondary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-secondary text-2xl font-heading">4</span>
          </div>
          <h3 class="font-heading text-lg mb-2">Isporuka</h3>
          <p class="text-text-light text-sm">U roku od 2 nedelje dobijate online galeriju spremnu za štampu.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Paketi -->
  <section id="paketi" class="py-20">
    <div class="container">
      <h2 class="text-3xl md:text-4xl font-heading text-center mb-4">
        Izaberite <span class="highlight">paket</span>
      </h2>
      <p class="text-text-light text-center max-w-2xl mx-auto mb-12">
        Fleksibilni paketi za kraće ili duže sesije — prilagođeni vašim potrebama.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Standard paket -->
        <div class="bg-white rounded-xl shadow-lg p-8 border border-secondary/10 hover:shadow-xl transition-shadow">
          <h3 class="text-2xl font-heading mb-2">Standard</h3>
          <p class="text-text-light mb-6">Za kraće sesije i manje porodice</p>
          <div class="text-center mb-6">
            <span class="text-5xl font-heading text-secondary">60€</span>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-center gap-3">
              <i class="fas fa-check text-secondary bg-secondary/10 w-6 h-6 rounded-full flex items-center justify-center text-xs"></i>
              <span>Trajanje: 1h</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fas fa-check text-secondary bg-secondary/10 w-6 h-6 rounded-full flex items-center justify-center text-xs"></i>
              <span>20 fotografija</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fas fa-check text-secondary bg-secondary/10 w-6 h-6 rounded-full flex items-center justify-center text-xs"></i>
              <span>Osnovna obrada fotografija</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fas fa-check text-secondary bg-secondary/10 w-6 h-6 rounded-full flex items-center justify-center text-xs"></i>
              <span>Odabir lokacije po želji</span>
            </li>
          </ul>
          <Button href="/contact" class="w-full text-center">Zakažite termin</Button>
        </div>

        <!-- Premium paket -->
        <div class="bg-white rounded-xl shadow-lg p-8 border-2 border-secondary relative hover:shadow-xl transition-shadow">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-secondary text-white px-4 py-1 rounded-full text-sm">
            Najpopularniji
          </div>
          <h3 class="text-2xl font-heading mb-2">Premium</h3>
          <p class="text-text-light mb-6">Za duže sesije sa više lokacija i scena</p>
          <div class="text-center mb-6">
            <span class="text-5xl font-heading text-secondary">100€</span>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-center gap-3">
              <i class="fas fa-check text-secondary bg-secondary/10 w-6 h-6 rounded-full flex items-center justify-center text-xs"></i>
              <span>Trajanje: 2h</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fas fa-check text-secondary bg-secondary/10 w-6 h-6 rounded-full flex items-center justify-center text-xs"></i>
              <span>40 fotografija</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fas fa-check text-secondary bg-secondary/10 w-6 h-6 rounded-full flex items-center justify-center text-xs"></i>
              <span>Osnovna obrada fotografija</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fas fa-check text-secondary bg-secondary/10 w-6 h-6 rounded-full flex items-center justify-center text-xs"></i>
              <span>Odabir lokacije po želji</span>
            </li>
            <li class="flex items-center gap-3">
              <i class="fas fa-check text-secondary bg-secondary/10 w-6 h-6 rounded-full flex items-center justify-center text-xs"></i>
              <span>Dodatne poze i scene</span>
            </li>
          </ul>
          <Button href="/contact" class="w-full text-center">Zakažite termin</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Galerija -->
  <section class="py-20 bg-primary/10">
    <div class="container">
      <h2 class="text-3xl md:text-4xl font-heading text-center mb-12">
        Iz mog <span class="highlight">objektiva</span>
      </h2>
      <div class="masonry-gallery">
        {galleryImages.map((image) => (
          <div class="masonry-item group relative overflow-hidden rounded-lg shadow-md">
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-auto group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <Button href="/portfolio" variant="outline">Pogledajte ceo portfolio</Button>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20">
    <div class="container">
      <h2 class="text-3xl md:text-4xl font-heading text-center mb-12">
        Često postavljana <span class="highlight">pitanja</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {faqs.map((faq) => (
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-heading text-lg mb-3">{faq.question}</h3>
            <p class="text-text-light text-sm">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-secondary/10">
    <div class="container text-center">
      <h2 class="text-3xl md:text-4xl font-heading mb-6">
        Spremni da <span class="highlight">sačuvamo</span> vaše porodične trenutke?
      </h2>
      <p class="text-text-light text-lg mb-8 max-w-2xl mx-auto">
        Kontaktirajte me i hajde da zajedno stvorimo fotografije koje ćete rado pokazivati godinama.
      </p>
      <Button href="/contact">Zakažite fotografisanje</Button>
    </div>
  </section>
</BaseLayout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Porodično fotografisanje",
  "description": "Profesionalno porodično fotografisanje u Beogradu. Prirodni i autentični porodični portreti na lokaciji po vašem izboru.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Dragana Korhner Photography",
    "telephone": "+381626618920",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Beograd",
      "addressCountry": "RS"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Beograd"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Paketi za porodično fotografisanje",
    "itemListElement": [
      {
        "@type": "Offer",
        "name": "Standard paket",
        "price": "60",
        "priceCurrency": "EUR",
        "description": "1h fotografisanja, 20 fotografija, osnovna obrada, odabir lokacije"
      },
      {
        "@type": "Offer",
        "name": "Premium paket",
        "price": "100",
        "priceCurrency": "EUR",
        "description": "2h fotografisanja, 40 fotografija, osnovna obrada, odabir lokacije, dodatne poze i scene"
      }
    ]
  }
}
</script>
