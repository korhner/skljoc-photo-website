---
export interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  title?: string;
  loading?: "eager" | "lazy";
  decoding?: "sync" | "async" | "auto";
  onload?: string;
}

const {
  src,
  alt,
  width = 800,
  height = 600,
  class: className = "",
  title,
  loading = "lazy",
  decoding = "async",
  onload
} = Astro.props;
---

<img
  src={src}
  alt={alt}
  width={width}
  height={height}
  class={className}
  title={title}
  loading={loading}
  decoding={decoding}
  onload={onload}
/>